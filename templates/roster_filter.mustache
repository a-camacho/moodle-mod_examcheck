{{!
    @template mod_examcheck/roster_filter

    Datafilter bar (keyword + group) for the checking roster, reusing the core
    datafilter partial and wiring it to the roster dynamic table.

    Example context (json):
    {
        "tableregionid": "examcheck-roster-12",
        "courseid": 2,
        "filtertypes": [
            {"name": "keywords", "title": "Search", "allowcustom": true, "allowmultiple": true,
             "filtertypeclass": "core/datafilter/filtertypes/keyword", "values": [], "joinlist": "[0,1,2]"}
        ],
        "rownumber": 1
    }
}}
<form method="dialog">
{{> core/datafilter/filter }}
</form>

{{#js}}
    require(['mod_examcheck/roster_filter'], function(RosterFilter) {
        RosterFilter.init('core-filter-{{uniqid}}');
    });
{{/js}}
